// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  REGULAR
  ADMIN
}

enum Genre {
  ACTION
  HORROR
  THRILLER
  ROMANCE
  COMEDY
}

enum SeatCategory {
  SILVER
  GOLD
  RECLINER
}

enum TimeSlot {
  MORNING
  EVENING
}

enum DayType{
  WEEKDAY
  WEEKEND
}


model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(REGULAR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Movie {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  posterUrl   String?
  releaseDate DateTime?
  genre       Genre
  runTime     Int

  shows Shows[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
 

  @@map("movies")
}

model Theater {
  id        Int      @id @default(autoincrement())
  name      String
  city      String
  state     String
  address   String
  screens   Screen[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pricing Pricing[]
  @@map("theaters")
}

model Screen {
   id           Int      @id @default(autoincrement())
  screenNumber Int
  rows         Int
  seatsPerRow  Int
  theaterId    Int
  seats        Seat[]
  shows        Shows[]
  theater      Theater  @relation(fields: [theaterId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("screens")
}


model Seat {
  id         Int          @id @default(autoincrement())
  row        String       // "A", "B", "C"
  seatNumber Int          // 1, 2, 3...
  category   SeatCategory
  screenId   Int
  screen     Screen       @relation(fields: [screenId], references: [id])

  @@unique([screenId, row, seatNumber])  // no duplicate seats
  @@map("seats")
}

model Pricing {
  id Int @id @default(autoincrement())
  price Decimal
  category SeatCategory
  slot TimeSlot
  dayType DayType
  theaterId Int
  theater      Theater  @relation(fields: [theaterId], references: [id])


  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt


  @@unique([theaterId, category, slot, dayType])
  @@map("pricing")
}

model Shows {
    id Int @id @default(autoincrement())
    movieId Int
    screenId Int
    showTime DateTime 

    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt


    movie Movie @relation(fields : [movieId], references: [id])
    screen Screen @relation(fields : [screenId], references: [id])

    @@map("shows")
}