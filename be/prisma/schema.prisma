// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  REGULAR
  ADMIN
}

enum Genre {
  ACTION
  HORROR
  THRILLER
  ROMANCE
  COMEDY
}

enum SeatCategory {
  SILVER
  GOLD
  RECLINER
}

enum TimeSlot {
  MORNING
  EVENING
}

enum DayType{
  WEEKDAY
  WEEKEND
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}


model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String?
  provider  String   @default("local")
  role      Role     @default(REGULAR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]

  @@map("users")
}

model Movie {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  posterUrl   String?
  releaseDate DateTime?
  genre       Genre
  runTime     Int

  shows       Shows[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
 

  @@map("movies")
}

model Theater {
  id        Int      @id @default(autoincrement())
  name      String
  city      String
  state     String
  address   String
  screens   Screen[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pricing Pricing[]
  @@map("theaters")
}

model Screen {
   id           Int      @id @default(autoincrement())
  screenNumber Int
  rows         Int
  seatsPerRow  Int
  theaterId    Int
  seats        Seat[]
  shows        Shows[]
  theater      Theater  @relation(fields: [theaterId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("screens")
}


model Seat {
  id         Int          @id @default(autoincrement())
  row        String       // "A", "B", "C"
  seatNumber Int          // 1, 2, 3...
  category   SeatCategory
  screenId   Int
  screen     Screen       @relation(fields: [screenId], references: [id], onDelete: Cascade)

  bookedSeats BookedSeat[]

  @@unique([screenId, row, seatNumber])  // no duplicate seats
  @@map("seats")
}

model Pricing {
  id Int @id @default(autoincrement())
  price Decimal
  category SeatCategory
  slot TimeSlot
  dayType DayType
  theaterId Int
  theater      Theater  @relation(fields: [theaterId], references: [id], onDelete: Cascade)


  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt


  @@unique([theaterId, category, slot, dayType])
  @@map("pricing")
}

model Shows {
    id Int @id @default(autoincrement())
    movieId Int
    screenId Int
    showTime DateTime
    slot     TimeSlot

    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt


    movie Movie @relation(fields : [movieId], references: [id], onDelete: Cascade)
    screen Screen @relation(fields : [screenId], references: [id], onDelete: Cascade)

    bookings    Booking[]
    bookedSeats BookedSeat[]

    @@unique([screenId, showTime])
    @@map("shows")
}

model Booking {
  id         Int           @id @default(autoincrement())
  userId     Int
  showId     Int
  totalPrice Decimal
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user       User          @relation(fields: [userId], references: [id])
  show       Shows         @relation(fields: [showId], references: [id], onDelete: Cascade)
  bookedSeats BookedSeat[]

  @@map("bookings")
}

model BookedSeat {
  id        Int     @id @default(autoincrement())
  bookingId Int
  seatId    Int
  showId    Int
  price     Decimal

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  seat      Seat    @relation(fields: [seatId], references: [id])
  show      Shows   @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@unique([seatId, showId])  // prevents double booking
  @@map("booked_seats")
}