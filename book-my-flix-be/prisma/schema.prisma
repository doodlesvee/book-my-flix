// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  REGULAR
  ADMIN
}

enum Genre {
  ACTION
  HORROR
  THRILLER
  ROMANCE
  COMEDY
}

enum SeatCategory {
  SILVER
  GOLD
  RECLINER
}


model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(REGULAR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Movie {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  posterUrl   String?
  releaseDate DateTime?
  genre       Genre
  runTime     Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
 

  @@map("movies")
}

model Theater {
  id        Int      @id @default(autoincrement())
  name      String
  city      String
  state     String
  address   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("theaters")
}

model Screen {
   id           Int      @id @default(autoincrement())
  screenNumber Int
  rows         Int
  seatsPerRow  Int
  theaterId    Int
  theater      Theater  @relation(fields: [theaterId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("screens")
}


model Seat {
  id         Int          @id @default(autoincrement())
  row        String       // "A", "B", "C"
  seatNumber Int          // 1, 2, 3...
  category   SeatCategory
  screenId   Int
  screen     Screen       @relation(fields: [screenId], references: [id])

  @@unique([screenId, row, seatNumber])  // no duplicate seats
  @@map("seats")
}
